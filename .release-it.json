{
  "git": {
    "tagName": "${version}",
    "commitMessage": "chore(release): ${version}"
  },
  "github": {
    "release": true,
    "releaseName": "${version}",
    "assets": [
      "dist/main.js",
      "dist/manifest.json",
      "dist/styles.css"
    ]
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": [
      "node scripts/update-versions.mjs",
      "yarn build"
    ]
  }
}
